---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/config";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../../utils/date-utils";
import { getTagUrl } from "../../../utils/url-utils";
import { PublishedDate } from "./atoms";
import { Category } from "./atoms";
import { WordCount } from "./atoms";
import { ReadingTime } from "./atoms";
import { EncryptedBadge } from "./atoms";

interface Props {
	published: Date;
	updated?: Date;
	category?: string;
	tags?: string[];
	hideUpdateDate?: boolean;
	hideTagsForMobile?: boolean;
	isHome?: boolean;
	className?: string;
	id?: string;
	showOnlyBasicMeta?: boolean;
	words?: number;
	minutes?: number;
	showWordCount?: boolean;
	showReadingTime?: boolean;
	showEncrypted?: boolean;
	postId?: string;
	showLikeCount?: boolean;
}

const {
	published,
	updated,
	category,
	tags,
	hideUpdateDate,
	hideTagsForMobile,
	isHome,
	className = "",
	id,
	showOnlyBasicMeta = false,
	words,
	minutes,
	showWordCount = false,
	showReadingTime = false,
	showEncrypted = false,
	postId,
	showLikeCount = false,
} = Astro.props;
---

<div class:list={["flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2", className]}>
    <PublishedDate date={published} />

    {!hideUpdateDate && updated && updated.getTime() !== published.getTime() && (
        <div class="flex items-center">
            <div class="meta-icon">
                <Icon name="material-symbols:edit-calendar-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium">{formatDateToYYYYMMDD(updated)}</span>
        </div>
    )}

    <Category category={category} />

    {showWordCount && words && (
        <WordCount words={words} />
    )}

    {showReadingTime && minutes && (
        <ReadingTime minutes={minutes} />
    )}

    {showLikeCount && postId && (
        <div class="flex items-center post-like-count" data-post-id={postId}>
            <div class="meta-icon">
                <Icon name="material-symbols:favorite-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium like-count-display">0</span>
        </div>
    )}

    {!showOnlyBasicMeta && (
        <div class:list={["items-center", {"flex": !hideTagsForMobile, "hidden md:flex": hideTagsForMobile}]}>
            <div class="meta-icon">
                <Icon name="material-symbols:tag-rounded" class="text-xl"></Icon>
            </div>
            <div class="flex flex-row flex-nowrap items-center">
                {(tags && tags.length > 0) && tags.map((tag, i) => (
                    <>
                        <div class:list={[{"hidden": i == 0}, "mx-1.5 text-[var(--meta-divider)] text-sm"]}>/</div>
                        <a href={getTagUrl(tag)} aria-label={`View all posts with the ${tag.trim()} tag`}
                           class="link-lg transition text-50 text-sm font-medium
                                        hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap">
                            {tag.trim()}
                        </a>
                    </>
                ))}
                {!(tags && tags.length > 0) && <div class="transition text-50 text-sm font-medium">{i18n(I18nKey.noTags)}</div>}
            </div>
        </div>
    )}
    
    {!isHome && id && (
        <div class="flex items-center umami-page-views hidden" data-id={id}>
            <div class="meta-icon">
                <Icon name="material-symbols:visibility-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium page-views-display">{i18n(I18nKey.pageViewsLoading)}</span>
        </div>
    )}

    {showEncrypted && (
        <EncryptedBadge />
    )}
    
    {!isHome && id && (
<script is:inline define:vars={{
    pageViewsText: i18n(I18nKey.profileStatsPageViews),
    visitsText: i18n(I18nKey.profileStatsVisits)
}}>
    function generateStatsText(pageViews, visits) {
        return `${pageViewsText} ${pageViews} · ${visitsText} ${visits}`;
    }

    async function fetchPageViews() {
        const container = document.querySelector('.umami-page-views');
        
        if (!window.oddmisc) {
            container?.classList.add('hidden');
            return;
        }

        const id = container?.dataset.id;
        if (!id) {return;}

        try {
            const stats = await window.oddmisc.getStats(`/posts/${id}/`);
            const pageViews = stats.pageviews || 0;
            const visits = stats.visits || 0;

            if (pageViews === 0 && visits === 0) {
                container?.classList.add('hidden');
                return;
            }

            container?.classList.remove('hidden');
            container.querySelector('.page-views-display').textContent = generateStatsText(pageViews, visits);
        } catch (error) {
            console.error('Error fetching page views:', error);
            container?.classList.add('hidden');
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fetchPageViews);
    } else {
        fetchPageViews();
    }
</script>
)}

{showLikeCount && (
<script is:inline define:vars={{
    abacusBase: "https://abacus.jasoncameron.dev",
    namespace: new URL(siteConfig.siteURL).hostname.replace(/[^a-zA-Z0-9_-]/g, "-")
}}>
    function safeKey(raw) {
        if (raw.length <= 32) return raw;
        let h = 0;
        for (let i = 0; i < raw.length; i++) {
            h = ((h << 5) - h + raw.charCodeAt(i)) | 0;
        }
        return `${raw.slice(0, 20)}-${(h >>> 0).toString(36)}`;
    }

    async function fetchLikeCounts() {
        const containers = document.querySelectorAll(".post-like-count[data-post-id]");
        if (!containers.length) return;

        await Promise.all(Array.from(containers).map(async (container) => {
            const postId = container.dataset.postId;
            if (!postId) return;

            const display = container.querySelector(".like-count-display");

            function toFiniteNumber(v) {
                const n = Number(v);
                return Number.isFinite(n) ? n : null;
            }

            function getPendingHits(id) {
                const pending = toFiniteNumber(localStorage.getItem(`like-pending-hits-post-${id}`));
                return pending && pending > 0 ? Math.floor(pending) : 0;
            }

            function getCachedServerCount(id) {
                const cached = toFiniteNumber(localStorage.getItem(`like-server-count-post-${id}`));
                const legacy = toFiniteNumber(localStorage.getItem(`like-count-post-${id}`));
                return (cached && cached >= 0 ? Math.floor(cached) : 0) ||
                    (legacy && legacy >= 0 ? Math.floor(legacy) : 0) ||
                    0;
            }

            try {
                const localServer = getCachedServerCount(postId);
                const localPending = getPendingHits(postId);
                if (display) display.textContent = String(Math.max(0, localServer + localPending));
            } catch {
                // ignore localStorage read errors
            }

            const key = safeKey(`post-${postId}`);
            const url = `${abacusBase}/get/${encodeURIComponent(namespace)}/${encodeURIComponent(key)}`;

            try {
                const res = await fetch(url);
                if (!res.ok) return;
                const data = await res.json();
                const value = typeof data?.value === "number" ? data.value : 0;

                let pendingHits = 0;
                try {
                    pendingHits = getPendingHits(postId);
                } catch {
                    // ignore localStorage read errors
                }

                if (display) {
                    display.textContent = String(Math.max(0, Math.floor(value) + pendingHits));
                }

                try {
                    localStorage.setItem(
                        `like-server-count-post-${postId}`,
                        String(Math.max(0, Math.floor(value))),
                    );
                } catch {
                    // ignore localStorage write errors
                }
            } catch {
                // keep cached/default value when request fails
            }
        }));
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fetchLikeCounts);
    } else {
        fetchLikeCounts();
    }
</script>
)}
