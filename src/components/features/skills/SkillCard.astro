---
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import Icon from "../../misc/Icon.astro";
import type { SkillCardProps } from "./types";

const { skill } = Astro.props as SkillCardProps;

const skillColor = skill.color || "#3B82F6";

const getLevelText = (level: string) => {
	switch (level) {
		case "unstarted":
			return "未入门";
		case "expert":
			return i18n(I18nKey.skillsExpert);
		case "advanced":
			return i18n(I18nKey.skillsAdvanced);
		case "intermediate":
			return i18n(I18nKey.skillsIntermediate);
		case "beginner":
			return i18n(I18nKey.skillsBeginner);
		default:
			return level;
	}
};

const getLevelWidth = (level: string) => {
	switch (level) {
		case "expert":
			return "100%";
		case "advanced":
			return "80%";
		case "intermediate":
			return "60%";
		case "beginner":
			return "40%";
		default:
			return "20%";
	}
};

const getLevelFromExperience = (
	exp?: { years: number; months: number },
): "unstarted" | "beginner" | "intermediate" | "advanced" | "expert" => {
	if (!exp) {
		return "unstarted";
	}

	const totalMonths = exp.years * 12 + exp.months;

	// Dynamic level thresholds by duration:
	// expert > 3 years, advanced > 2 years, intermediate > 1 year, beginner <= 1 year
	if (totalMonths > 36) {
		return "expert";
	}
	if (totalMonths > 24) {
		return "advanced";
	}
	if (totalMonths > 12) {
		return "intermediate";
	}
	return "beginner";
};

const warnInvalidSkillDate = (field: "startedAt" | "endedAt", rawValue: string) => {
	if (!import.meta.env.DEV) {
		return;
	}
	console.warn(
		`[skills] Invalid ${field} for "${skill.id}" (${skill.name}): "${rawValue}". Expected format: YYYY-MM`,
	);
};

const parseSkillYearMonth = (
	value: string | undefined,
	field: "startedAt" | "endedAt",
): { year: number; month: number } | null => {
	if (!value) {
		return null;
	}

	const match = value.trim().match(/^(\d{4})-(\d{2})$/);
	if (!match) {
		warnInvalidSkillDate(field, value);
		return null;
	}

	const year = Number(match[1]);
	const month = Number(match[2]);
	if (!Number.isInteger(year) || !Number.isInteger(month)) {
		warnInvalidSkillDate(field, value);
		return null;
	}
	if (month < 1 || month > 12) {
		warnInvalidSkillDate(field, value);
		return null;
	}

	return { year, month };
};

const getDurationFromDates = (
	startedAt?: string,
	endedAt?: string,
): { years: number; months: number } | null => {
	const start = parseSkillYearMonth(startedAt, "startedAt");
	if (!start) {
		return null;
	}

	const now = new Date();
	const end = parseSkillYearMonth(endedAt, "endedAt") || {
		year: now.getFullYear(),
		month: now.getMonth() + 1,
	};

	const startTotalMonths = start.year * 12 + (start.month - 1);
	const endTotalMonths = end.year * 12 + (end.month - 1);

	if (startTotalMonths > endTotalMonths) {
		return null;
	}

	const diffTotalMonths = endTotalMonths - startTotalMonths;
	const years = Math.floor(diffTotalMonths / 12);
	const months = diffTotalMonths % 12;

	return { years, months };
};

const formatExperience = (exp?: { years: number; months: number }) => {
	if (!exp) {
		return "";
	}
	const parts: string[] = [];
	if (exp.years > 0) {
		parts.push(`${exp.years} ${i18n(I18nKey.skillYears)}`);
	}
	if (exp.months > 0) {
		parts.push(`${exp.months} ${i18n(I18nKey.skillMonths)}`);
	}
	return parts.join(" ");
};

const computedExperience = getDurationFromDates(skill.startedAt, skill.endedAt);
const displayExperience = formatExperience(computedExperience || undefined);
const displayLevel = getLevelFromExperience(computedExperience || undefined);
const getProgressWidthFromExperience = (
	exp?: { years: number; months: number },
): string => {
	if (!exp) {
		return "0%";
	}

	// Map duration to progress with a 3-year cap:
	// 0 months -> 0%, 36 months+ -> 100%
	const totalMonths = exp.years * 12 + exp.months;
	const percentage = Math.min((totalMonths / 36) * 100, 100);
	return `${Math.max(0, percentage)}%`;
};
const progressWidth = getProgressWidthFromExperience(computedExperience || undefined);
---

<div
	class="skill-card group relative bg-transparent rounded-xl border border-black/10 dark:border-white/10 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
	data-category={skill.category}
>
	<div class="p-5">
		<div class="flex items-start gap-4 mb-3">
			<div
				class="w-12 h-12 flex-shrink-0 rounded-lg flex items-center justify-center"
				style={`background-color: ${skillColor}20`}
			>
				<Icon
					icon={skill.icon}
					class="text-xl"
					color={skillColor}
					fallback={skill.name.charAt(0)}
					loading="eager"
				/>
			</div>

			<div class="flex-1 min-w-0">
				<div class="flex items-center justify-between mb-1">
					<h3
						class="text-lg font-bold text-black/90 dark:text-white/90 truncate group-hover:text-[var(--primary)] transition-colors duration-200"
					>
						{skill.name}
					</h3>
					<span
						class="shrink-0 ml-2 px-2 py-0.5 text-xs rounded-md bg-[var(--primary)]/10 text-[var(--primary)] font-medium"
					>
						{getLevelText(displayLevel)}
					</span>
				</div>
				{displayExperience && (
					<p class="text-xs text-black/50 dark:text-white/50">
						{displayExperience}
					</p>
				)}
			</div>
		</div>

		<p
			class="text-sm text-black/60 dark:text-white/60 line-clamp-2 min-h-[2.5rem]"
		>
			{skill.description}
		</p>

		<div class="mt-3 w-full bg-[var(--btn-regular-bg)] rounded-full h-1.5">
			<div
				class="h-1.5 rounded-full transition-all duration-500"
				style={`width: ${progressWidth}; background-color: ${skillColor}`}
			>
			</div>
		</div>
	</div>

	<div
		class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
	>
	</div>
</div>

<style>
	.skill-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
	}

	.skill-card.filtered-out {
		display: none;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.skill-card:nth-child(1) {
		animation-delay: 0.03s;
	}
	.skill-card:nth-child(2) {
		animation-delay: 0.06s;
	}
	.skill-card:nth-child(3) {
		animation-delay: 0.09s;
	}
	.skill-card:nth-child(4) {
		animation-delay: 0.12s;
	}
	.skill-card:nth-child(5) {
		animation-delay: 0.15s;
	}
	.skill-card:nth-child(6) {
		animation-delay: 0.18s;
	}
	.skill-card:nth-child(7) {
		animation-delay: 0.21s;
	}
	.skill-card:nth-child(8) {
		animation-delay: 0.24s;
	}
	.skill-card:nth-child(9) {
		animation-delay: 0.27s;
	}
	.skill-card:nth-child(10) {
		animation-delay: 0.3s;
	}
	.skill-card:nth-child(11) {
		animation-delay: 0.33s;
	}
	.skill-card:nth-child(12) {
		animation-delay: 0.36s;
	}

	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
